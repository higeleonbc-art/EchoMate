# LoL ADC Coach - 環境変数サンプル
# このファイルを .env にコピーして値を埋める

# ===== Riot API =====
# https://developer.riotgames.com/ で取得（個人キーは24h有効）
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# プラットフォームルーティング: jp1 / kr / na1 / euw1 / eun1 / br1 / la1 / la2 / oc1 / tr1 / ru
RIOT_PLATFORM=jp1

# ===== Ollama =====
# コーチコメント生成に使うモデル（既定 qwen3:8b）
# 旧EchoMate由来の echomate-base / echomate-echo は使わないこと（キャラ会話用FTモデル）
COACH_MODEL=qwen3:8b

# Ollama HTTPエンドポイント（既定でOK）
OLLAMA_CHAT_API_URL=http://localhost:11434/api/chat

# コーチLLM呼び出しタイムアウト秒（既定180、初回ロードを考慮）
COACH_TIMEOUT=180

# ===== LCU =====
# 通常は自動検出。明示指定したい場合のみ設定
# RIOT_LCU_LOCKFILE=C:\Riot Games\League of Legends\lockfile
