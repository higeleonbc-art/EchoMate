    "last_updated": "2026-05-09",
    "patch": "16.x想定",
    "philosophy": "1コアは Mythic / 強Spike アイテム。2-3コアで敵構成 (armor/AP/assassin/tank) に応じて動的選択。",
    "key_categories": {
      "vs_armor_heavy": "敵タンク・ブルーザーが多い時 (Maokai/Trundle/Mundo/Sion等) → 防具貫通",
      "vs_ap_heavy": "敵にAPが3人以上 (Brand/Syndra/Vex等) → 魔法防御 or QSS系",
      "vs_assassin": "敵にassassin/burst (Zed/Rengar/Talon/Diana等) → spell shield/GA",
      "vs_engage_heavy": "敵にengage多数 (Malphite/Leona/Maokai/Amumu等) → mobility/peel",
      "vs_kite_heavy": "敵に高機動 (Yasuo/Yone/Akali等) → 自衛"
    }
  },
